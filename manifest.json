{
    "manifest_version": 3,
    "name": "Bookmark Syncer",
    "version": "1.0",
    "description": "Sync your bookmarks to a landing page",
    "permissions": [
        "bookmarks",
        "history",
        "storage",
        "activeTab",
        "tabs"
    ],
    "host_permissions": [
        "https://generativelanguage.googleapis.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "index.html"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "action": {
        "default_popup": "popup.html"
    }
}