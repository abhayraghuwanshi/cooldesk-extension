{
  "manifest_version": 3,
  "name": "cooldesk",
  "version": "0.1.0",
  "action": {
    "default_title": "Open CoolDesk Sidebar"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "options_page": "index.html",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "history",
    "bookmarks",
    "tabs",
    "windows",
    "sidePanel",
    "search",
    "scripting",
    "idle",
    "activeTab",
    "contextMenus",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://accounts.google.com/*",
    "https://apis.google.com/*",
    "https://www.googleapis.com/*",
    "https://firestore.googleapis.com/*",
    "https://identitytoolkit.googleapis.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://*.googleapis.com https://*.firebaseapp.com https://*.firebaseio.com https://identitytoolkit.googleapis.com https://firestore.googleapis.com http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:*"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "index.html",
        "src/footerBar.js",
        "src/contentInteractions.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "src/interactionContent.js"
      ],
      "run_at": "document_idle"
    }
  ]
}