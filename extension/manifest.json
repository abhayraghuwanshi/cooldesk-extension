{
  "manifest_version": 3,
  "name": "cooldesk",
  "version": "0.1.0",
  "action": {
    "default_title": "cooldesk",
    "default_popup": "index.html"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "options_page": "index.html",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "bookmarks",
    "history",
    "tabs",
    "sidePanel",
    "search"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "index.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}