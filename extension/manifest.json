{
  "manifest_version": 3,
  "name": "cooldesk",
  "version": "0.1.0",
  "action": {
    "default_title": "Open CoolDesk Sidebar"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "options_page": "index.html",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "history",
    "bookmarks",
    "tabs",
    "windows",
    "scripting",
    "idle",
    "activeTab",
    "sessions"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://*.google.com https://*.gstatic.com https://speech.googleapis.com https://*.googleapis.com http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:*; img-src 'self' data: blob: https: http:; media-src 'self' data: blob:; font-src 'self' data:;"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "index.html",
        "logo.png",
        "src/footerBar.js",
        "src/contentInteractions.js",
        "dist/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "src/interactionContent.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://grok.com/*"
      ],
      "js": [
        "src/chatScraper.js"
      ],
      "run_at": "document_idle"
    }
  ]
}