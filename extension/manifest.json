{
  "manifest_version": 3,
  "name": "New Tab by Cooldesk - Start Smarter",
  "version": "1.0.4",
  "action": {
    "default_title": "Open CoolDesk Sidebar"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "options_page": "index.html",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "history",
    "bookmarks",
    "tabs",
    "tabGroups",
    "windows",
    "scripting",
    "idle",
    "activeTab",
    "sessions",
    "sidePanel",
    "search",
    "alarms",
    "commands"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' wss://signaling-server.raghuwanshi-abhay405.workers.dev; frame-src https://calendar.google.com https://www.google.com"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "dist/*",
        "src/components/footerBar.js",
        "src/content-scripts/contentInteractions.js",
        "src/scrapers/chatScraper.js",
        "src/scrapers/calendarScraper.js",
        "logo-2.png",
        "index.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*/*"
      ],
      "js": [
        "src/content-scripts/interactionContent.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://aistudio.google.com/*",
        "https://lovable.dev/*"
      ],
      "js": [
        "src/scrapers/chatScraper.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://calendar.google.com/*"
      ],
      "js": [
        "src/scrapers/calendarScraper.js"
      ],
      "run_at": "document_idle"
    }
  ]
}