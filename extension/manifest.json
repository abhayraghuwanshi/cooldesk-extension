{
  "manifest_version": 3,
  "name": "cooldesk",
  "version": "0.1.0",
  "action": {
    "default_title": "Open CoolDesk Sidebar"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "options_page": "index.html",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "history",
    "bookmarks",
    "tabs",
    "windows",
    "sidePanel",
    "search",
    "scripting",
    "idle",
    "activeTab",
    "contextMenus",
    "sessions"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "index.html",
        "logo.png",
        "src/footerBar.js",
        "src/contentInteractions.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "src/interactionContent.js"
      ],
      "run_at": "document_idle"
    }
  ]
}