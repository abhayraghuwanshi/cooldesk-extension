{
  "manifest_version": 3,
  "name": "New Tab by Cooldesk - Start Smarter",
  "version": "1.0.5",
  "action": {
    "default_title": "Open CoolDesk Sidebar"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "options_page": "index.html",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "history",
    "bookmarks",
    "tabs",
    "tabGroups",
    "windows",
    "scripting",
    "idle",
    "activeTab",
    "sessions",
    "sidePanel",
    "search",
    "alarms",
    "commands"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' wss://signaling-server.raghuwanshi-abhay405.workers.dev http://localhost:5173 ws://localhost:5173; frame-src https://calendar.google.com https://www.google.com"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "dist/*",
        "src/components/footerBar.js",
        "src/content-scripts/contentInteractions.js",
        "src/scrapers/clickToScrape.js",
        "src/scrapers/genericLinkScraper.js",
        "logo-2.png",
        "index.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*/*"
      ],
      "js": [
        "src/content-scripts/interactionContent.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "open_spotlight": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S",
        "windows": "Alt+S"
      },
      "description": "Open CoolDesk Spotlight Search"
    },
    "toggle_sidebar": {
      "suggested_key": {
        "default": "Alt+B",
        "mac": "Command+Shift+S",
        "windows": "Alt+B"
      },
      "description": "Toggle CoolDesk Sidebar"
    }
  }
}