{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "spotlight"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "node",
          "cmd": "node",
          "args": true
        },
        {
          "name": "AppScanner",
          "cmd": "bin/AppScanner",
          "args": []
        },
        {
          "name": "BrowserFocus",
          "cmd": "bin/BrowserFocus",
          "args": []
        },
        {
          "name": "AppFocus",
          "cmd": "bin/AppFocus",
          "args": []
        }
      ]
    }
  ]
}