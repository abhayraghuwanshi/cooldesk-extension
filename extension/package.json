{
  "name": "cooldesk-extension",
  "productName": "CoolDesk",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite --mode electron\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "build:electron": "vite build --mode electron",
    "electron": "electron .",
    "package:win": "set CSC_IDENTITY_AUTO_DISCOVERY=false && npm run build:electron && npx electron-builder --win",
    "package:mac": "npm run build:electron && npx electron-builder --mac",
    "package:linux": "npm run build:electron && npx electron-builder --linux",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.0.1",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.0.0",
    "@fortawesome/react-fontawesome": "^0.2.3",
    "node-llama-cpp": "^3.0.0",
    "@tiptap/extension-bubble-menu": "2.26.0",
    "@tiptap/extension-floating-menu": "2.26.0",
    "@tiptap/extension-image": "^2.26.0",
    "@tiptap/extension-link": "2.26.0",
    "@tiptap/extension-placeholder": "2.26.0",
    "@tiptap/extension-table": "^2.26.0",
    "@tiptap/extension-table-cell": "^2.26.0",
    "@tiptap/extension-table-header": "^2.26.0",
    "@tiptap/extension-table-row": "^2.26.0",
    "@tiptap/extension-task-item": "2.26.0",
    "@tiptap/extension-task-list": "2.26.0",
    "@tiptap/extension-underline": "2.26.0",
    "@tiptap/react": "2.26.0",
    "@tiptap/starter-kit": "2.26.0",
    "annyang": "^2.6.1",
    "buffer": "^6.0.3",
    "crypto-js": "^4.2.0",
    "elliptic": "^6.6.1",
    "fuse.js": "^7.1.0",
    "open": "^11.0.0",
    "process": "^0.11.10",
    "ps-list": "^9.0.0",
    "psl": "^1.15.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "y-indexeddb": "^9.0.12",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.1.0",
    "@eslint/js": "^9.33.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "vite": "^7.1.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.cooldesk.app",
    "productName": "CoolDesk",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "electron-main.js",
      "electron-preload.js",
      "src/ai/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/node-llama-cpp",
        "to": "node_modules/node-llama-cpp"
      }
    ],
    "asarUnpack": [
      "node_modules/node-llama-cpp/**/*"
    ],
    "win": {
      "target": "dir",
      "icon": "public/icon-128.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/icon-128.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/icon-128.png",
      "category": "Utility"
    }
  }
}
