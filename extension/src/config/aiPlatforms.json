{
  "platforms": [
    {
      "id": "chatgpt",
      "name": "ChatGPT",
      "domains": [
        "chat.openai.com",
        "chatgpt.com"
      ],
      "color": "#10A37F",
      "icon": "🤖",
      "urlPatterns": {
        "include": [
          "chat\\.openai\\.com/c/[a-f0-9-]{8,}",
          "chatgpt\\.com/c/[a-f0-9-]{8,}"
        ],
        "exclude": [
          "chat\\.openai\\.com/?$",
          "chatgpt\\.com/?$",
          "/new$",
          "/share/"
        ]
      },
      "titleExtraction": {
        "type": "chatId",
        "pattern": "/c/([a-f0-9-]+)",
        "format": "ChatGPT Chat {id}"
      }
    },
    {
      "id": "claude",
      "name": "Claude",
      "domains": [
        "claude.ai"
      ],
      "color": "#D97706",
      "icon": "🧠",
      "urlPatterns": {
        "include": [
          "claude\\.ai/chat/[a-f0-9-]{8,}"
        ],
        "exclude": [
          "claude\\.ai/?$",
          "claude\\.ai/new$",
          "claude\\.ai/chat/?$",
          "claude\\.ai/settings",
          "claude\\.ai/api",
          "claude\\.ai/docs",
          "claude\\.ai/help",
          "claude\\.ai/login",
          "claude\\.ai/signup"
        ]
      },
      "titleExtraction": {
        "type": "chatId",
        "pattern": "/chat/([a-f0-9-]+)",
        "format": "Claude Chat {id}"
      }
    },
    {
      "id": "gemini",
      "name": "Gemini",
      "domains": [
        "gemini.google.com"
      ],
      "color": "#4285F4",
      "icon": "✨",
      "urlPatterns": {
        "include": [
          "gemini\\.google\\.com/app/[a-f0-9]{8,}"
        ],
        "exclude": [
          "gemini\\.google\\.com/?$",
          "gemini\\.google\\.com/app/?$"
        ]
      },
      "titleExtraction": {
        "type": "chatId",
        "pattern": "/app/([a-f0-9]+)",
        "format": "Gemini Chat {id}"
      }
    },
    {
      "id": "perplexity",
      "name": "Perplexity",
      "domains": [
        "perplexity.ai"
      ],
      "color": "#6B5BFF",
      "icon": "🌀",
      "urlPatterns": {
        "include": [
          "perplexity\\.ai/search/[^?]+",
          "www\\.perplexity\\.ai/search/[^?]+"
        ],
        "exclude": [
          "perplexity\\.ai/?$",
          "www\\.perplexity\\.ai/?$"
        ]
      },
      "titleExtraction": {
        "type": "queryParam",
        "parameter": "q",
        "maxLength": 50,
        "fallback": "Perplexity Search"
      }
    },
    {
      "id": "copilot",
      "name": "Copilot",
      "domains": [
        "copilot.microsoft.com"
      ],
      "color": "#0078D4",
      "icon": "💫",
      "urlPatterns": {
        "include": [
          "copilot\\.microsoft\\.com/[^?]+",
          "copilot\\.microsoft\\.com/.*conversation"
        ],
        "exclude": [
          "copilot\\.microsoft\\.com/?$"
        ]
      },
      "titleExtraction": {
        "type": "fallback",
        "format": "Copilot Chat"
      }
    },
    {
      "id": "grok",
      "name": "Grok",
      "domains": [
        "grok.com"
      ],
      "color": "#000000",
      "icon": "𝕏",
      "urlPatterns": {
        "include": [
          "grok\\.com/chat/[a-f0-9-]{8,}",
          "x\\.com/i/grok\\?conversation=\\d+"
        ],
        "exclude": [
          "grok\\.com/?$",
          "x\\.com/?$",
          "x\\.com/[^/]+/?$",
          "x\\.com/.*/status/",
          "x\\.com/i/grok/?$"
        ]
      },
      "titleExtraction": {
        "type": "multi",
        "patterns": [
          {
            "pattern": "grok\\.com/chat/([a-f0-9-]+)",
            "format": "Grok Chat {id}"
          },
          {
            "pattern": "x\\.com/i/grok\\?conversation=(\\d+)",
            "format": "Grok Chat {id}"
          }
        ]
      }
    }
  ],
  "globalExcludes": [
    "/new$",
    "/new/",
    "utm_source=",
    "utm_medicum=",
    "utm_campaign=",
    "/login$",
    "/login/",
    "/logout$",
    "/logout/"
  ],
  "fallbackTitleFormat": "{platform} Chat - {time}"
}