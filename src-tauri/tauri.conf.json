{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "cooldesk",
  "version": "1.1.0",
  "identifier": "com.cooldesk.app",
  "build": {
    "frontendDist": "../dist-tauri",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "CoolDesk",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "spotlight",
        "title": "CoolDesk Spotlight",
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "shadow": false,
        "url": "spotlight.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM0OEUzMkNGOUY5M0Q5REYKUldUZjJaT2Z6ektPTk9hUVhxdU43N1QvTlJHYVdLMUJhdGRMalBzUldXdVUwRGlROXdpOVB6d3IK",
      "endpoints": [
        "https://github.com/abhayraghuwanshi/cooldesk-extension/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/AppScanner",
      "bin/AppMatcher"
    ]
  }
}